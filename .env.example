# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Docker app web interface: http://localhost
APP_PORT="80"

# Local PostgreSQL / pgAdmin defaults for Docker Compose.
# Copy this file to .env if you want to override these values.
POSTGRES_DB="quizz"
POSTGRES_USER="quizz_app"
POSTGRES_PASSWORD="quizz_app_password"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://quizz_app:quizz_app_password@localhost:5432/quizz"

# Backend API defaults.
API_PORT="3001"
API_PROXY_TARGET="http://localhost:3001"
# Inside Docker Compose, the API uses host "postgres" instead of localhost:
# postgresql://quizz_app:quizz_app_password@postgres:5432/quizz

# Ranking CSV export. The separate listener service must verify the HMAC headers with the same secret.
RANKING_EXPORT_URL="http://henkel-totem.novaxd.com.br:8080/rankings/upload"
RANKING_EXPORT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
RANKING_EXPORT_KEY_ID="henkel-quiz-totem"
RANKING_EXPORT_TIMEOUT_MS="15000"

# pgAdmin web interface: http://localhost:5050
PGADMIN_DEFAULT_EMAIL="admin@henkel.com"
PGADMIN_DEFAULT_PASSWORD="admin"
PGADMIN_PORT="5050"
